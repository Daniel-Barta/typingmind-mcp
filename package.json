{
  "name": "@typingmind/mcp",
  "version": "1.2.1",
  "repository": "https://github.com/TypingMind/typingmind-mcp",
  "description": "Model Context Protocol (MCP) servers runner for TypingMind",
  "main": "dist/lib/server.js",
  "bin": {
    "@typingmind/mcp": "./dist/bin/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/bin/index.js",
    "clean": "rimraf dist",
    "prebuild": "pnpm run clean",
    "prepublishOnly": "pnpm build",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check ."
  },
  "keywords": [
    "ai",
    "mcp",
    "model",
    "context",
    "protocol",
    "typingmind"
  ],
  "author": "TypingMind",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.2.1",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "json-stable-stringify": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.7",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "@types/node": "^24.3.0",
    "@types/express": "^5.0.3",
    "@types/cors": "^2.8.19"
  }
}