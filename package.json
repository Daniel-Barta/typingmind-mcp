    "model",
    "context",
    "protocol",
    "typingmind"
  ],
  "author": "TypingMind",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
