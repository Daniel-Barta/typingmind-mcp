    "json-stable-stringify": "^1.2.1"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "^5.6.3",
    "@types/node": "^22.7.5",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/json-stable-stringify": "^1.0.36"
  }
