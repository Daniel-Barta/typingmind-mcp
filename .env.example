# Example environment configuration for typingmind-mcp
# Copy this file to `.env` and adjust values as needed.

# Authentication (required)
# If not provided via CLI argument, the server will read this value.
# Example: MCP_AUTH_TOKEN=your-typingmind-token
MCP_AUTH_TOKEN=

# Network binding
# Only HOST is supported. Default is 0.0.0.0 (all interfaces)
# Set to 127.0.0.1 to restrict to local machine only.
HOST=
PORT=50880

# HTTPS (optional)
# When both are provided, the server will run over HTTPS.
# Provide absolute paths or paths relative to the project root.
CERTFILE=
KEYFILE=

# Notes:
# - Values in this file are loaded by dotenv. Do not quote values unless needed.
# - Empty values are ignored; unset any variable by leaving it blank.
